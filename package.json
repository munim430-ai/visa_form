{
  "name": "visa-form",
  "version": "1.0.0",
  "description": "Korea D-4-1 Visa Application Form Generator",
  "author": "Hasibul Munim",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.visa.formdocx",
    "productName": "Visa Form",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "src/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "extraResources": [
      {
        "from": "templates/",
        "to": "templates/"
      },
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "portable": {
      "artifactName": "KoreaVisaForm.exe"
    }
  }
}
